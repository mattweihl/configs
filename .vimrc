filetype plugin indent on
syntax on

runtime macros/matchit.vim

colorscheme dracula
set background=dark

set backspace=indent,eol,start
set hidden                    
set incsearch                 
set ruler                     
set wildmenu                  
set number 
set mouse=a
set hlsearch
set incsearch

" Tab settings
set autoindent
set shiftwidth=4
set softtabstop=4
set expandtab

" Show chars for tabs.
set list
set listchars=tab:␉·
set clipboard=unnamed

noremap <Up>    <Nop>
noremap <Down>  <Nop>
noremap <Left>  <Nop>
noremap <Right> <Nop>
